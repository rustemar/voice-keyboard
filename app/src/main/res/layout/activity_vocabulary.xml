<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/keyboard_bg"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/vocabulary_title"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vocabulary_description"
        android:textColor="@color/status_text"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/editVocabularyWord"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/vocabulary_input_hint"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/status_text"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnVocabularyAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vocabulary_add"
            android:textColor="@color/white"
            android:backgroundTint="@color/mic_idle" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtVocabularyCounter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/status_text"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtVocabularyEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vocabulary_empty"
        android:textColor="@color/status_text"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerVocabulary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
