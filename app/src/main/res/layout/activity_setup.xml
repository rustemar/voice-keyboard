<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/keyboard_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_enable_instructions"
            android:textColor="@color/status_text"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Theme -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme"
            android:textColor="@color/key_text"
            android:textSize="14sp" />
        <Spinner
            android:id="@+id/spinnerTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginBottom="16dp" />

        <!-- Interface Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_interface_language"
            android:textColor="@color/key_text"
            android:textSize="14sp" />
        <Spinner
            android:id="@+id/spinnerLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginBottom="16dp" />

        <!-- API Key -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_api_key"
            android:textColor="@color/key_text"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/txtGetApiKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_get_api_key"
            android:textColor="@color/mic_idle"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:clickable="true"
            android:focusable="true" />
        <EditText
            android:id="@+id/editApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginBottom="16dp" />

        <!-- Endpoint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_endpoint"
            android:textColor="@color/key_text"
            android:textSize="14sp" />
        <EditText
            android:id="@+id/editEndpoint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginBottom="16dp" />

        <!-- Model -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_model"
            android:textColor="@color/key_text"
            android:textSize="14sp" />
        <EditText
            android:id="@+id/editModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginBottom="16dp" />

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_language"
            android:textColor="@color/key_text"
            android:textSize="14sp" />
        <EditText
            android:id="@+id/editLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginBottom="16dp" />

        <!-- Prompt -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_prompt"
            android:textColor="@color/key_text"
            android:textSize="14sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_prompt_hint"
            android:textColor="@color/status_text"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/editPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginBottom="16dp" />

        <!-- Auto record -->
        <Switch
            android:id="@+id/switchAutoRecord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_auto_record"
            android:textColor="@color/key_text"
            android:thumbTint="@color/switch_thumb_color"
            android:trackTint="@color/switch_track_color"
            android:layout_marginBottom="12dp" />

        <!-- Add trailing space -->
        <Switch
            android:id="@+id/switchAddSpace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_add_space"
            android:textColor="@color/key_text"
            android:thumbTint="@color/switch_thumb_color"
            android:trackTint="@color/switch_track_color"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnApply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_apply"
            android:textColor="@color/white"
            android:backgroundTint="@color/mic_idle" />

        <!-- API validation status -->
        <TextView
            android:id="@+id/txtApiStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

        <!-- Post-processing settings -->
        <Button
            android:id="@+id/btnPostProcessing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pp_open_settings"
            android:textColor="@color/white"
            android:backgroundTint="@color/mic_idle"
            android:layout_marginBottom="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Test section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/test_section_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/test_section_hint"
            android:textColor="@color/status_text"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <!-- Test result area -->
        <TextView
            android:id="@+id/txtTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@color/test_result_bg"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:hint="@string/test_result_placeholder"
            android:textColorHint="@color/status_text"
            android:gravity="top" />

        <!-- Test status -->
        <TextView
            android:id="@+id/txtTestStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Test buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnTestRecord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/test_record"
                android:textColor="@color/white"
                android:backgroundTint="@color/mic_recording"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnTestClear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/test_clear"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/key_bg" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Logs section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/logs_section_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/logs_section_hint"
            android:textColor="@color/status_text"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnSaveLogs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/logs_save"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/key_bg"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnClearLogs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/logs_clear"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/key_bg" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Update section -->
        <Button
            android:id="@+id/btnCheckUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/update_check"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/key_bg"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/status_text"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtGithub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/about_project"
            android:textColor="@color/mic_idle"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
