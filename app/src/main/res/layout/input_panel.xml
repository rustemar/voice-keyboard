<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/keyboard_bg"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="16dp">

    <!-- Clipboard paste bar (like Google Keyboard) -->
    <LinearLayout
        android:id="@+id/clipboardBar"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/clipboard_bar_bg"
        android:paddingStart="12dp"
        android:paddingEnd="14dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_paste"
            android:scaleType="centerInside"
            app:tint="@color/key_text" />

        <TextView
            android:id="@+id/clipboardText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/key_text"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:maxWidth="240dp" />
    </LinearLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/status_idle"
        android:textColor="@color/status_text"
        android:textSize="13sp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/clipboardBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hide keyboard button (top left) -->
    <ImageButton
        android:id="@+id/btnHideKeyboard"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/borderless_ripple"
        android:src="@drawable/ic_keyboard_hide"
        android:contentDescription="Hide keyboard"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/status_text" />

    <!-- Settings button (below switch IME) -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/borderless_ripple"
        android:src="@android:drawable/ic_menu_manage"
        android:contentDescription="Settings"
        android:scaleType="centerInside"
        app:layout_constraintTop_toBottomOf="@id/btnHideKeyboard"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp"
        app:tint="@color/status_text" />

    <!-- Cut all text button (left of backspace) -->
    <ImageButton
        android:id="@+id/btnCutAll"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/key_bg"
        android:src="@drawable/ic_cut"
        android:contentDescription="Cut all"
        android:scaleType="centerInside"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnBackspace"
        android:layout_marginEnd="6dp"
        app:tint="@color/key_text" />

    <!-- Backspace button (top right, with long-press repeat) -->
    <ImageButton
        android:id="@+id/btnBackspace"
        android:layout_width="56dp"
        android:layout_height="42dp"
        android:background="@drawable/key_bg"
        android:src="@drawable/ic_backspace"
        android:contentDescription="Backspace"
        android:scaleType="centerInside"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/key_text" />

    <!-- Mic button -->
    <FrameLayout
        android:id="@+id/micFrame"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp">

        <!-- Ripple layers for recording animation -->
        <View
            android:id="@+id/ripple1"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/ripple_circle"
            android:alpha="0"
            android:scaleX="1"
            android:scaleY="1" />

        <View
            android:id="@+id/ripple2"
            android:layout_width="108dp"
            android:layout_height="108dp"
            android:layout_gravity="center"
            android:background="@drawable/ripple_circle"
            android:alpha="0"
            android:scaleX="1"
            android:scaleY="1" />

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:background="@drawable/mic_button_bg"
            android:src="@drawable/ic_mic"
            android:contentDescription="Record"
            android:scaleType="centerInside"
            android:padding="16dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/mic_transcribing" />

        <TextView
            android:id="@+id/queueBadge"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/queue_badge_bg"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Cancel button (left of mic) -->
    <ImageButton
        android:id="@+id/btnCancel"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/borderless_ripple"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:contentDescription="Cancel"
        android:scaleType="centerInside"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/micFrame"
        app:layout_constraintBottom_toBottomOf="@id/micFrame"
        app:layout_constraintEnd_toStartOf="@id/micFrame"
        app:tint="@color/status_text" />

    <!-- Post-processing toggle row (above bottom row, left-aligned) -->
    <LinearLayout
        android:id="@+id/ppToggleRow"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/micFrame"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnPpFix"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="@drawable/toggle_key_bg"
            android:src="@drawable/ic_fix_text"
            android:contentDescription="@string/pp_fix"
            android:scaleType="centerInside"
            android:padding="6dp"
            app:tint="@color/key_text" />

        <View
            android:layout_width="4dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnPpShorten"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="@drawable/toggle_key_bg"
            android:src="@drawable/ic_shorten"
            android:contentDescription="@string/pp_shorten"
            android:scaleType="centerInside"
            android:padding="6dp"
            app:tint="@color/key_text" />

        <View
            android:layout_width="4dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnPpEmoji"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="@drawable/toggle_key_bg"
            android:src="@drawable/ic_emoji"
            android:contentDescription="@string/pp_emoji"
            android:scaleType="centerInside"
            android:padding="6dp"
            app:tint="@color/key_text" />

        <View
            android:layout_width="4dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnPpRhyme"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="@drawable/toggle_key_bg"
            android:src="@drawable/ic_rhyme"
            android:contentDescription="@string/pp_rhyme"
            android:scaleType="centerInside"
            android:padding="6dp"
            app:tint="@color/key_text" />

        <View
            android:layout_width="4dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnPpTerminal"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="@drawable/toggle_key_bg"
            android:src="@drawable/ic_terminal"
            android:contentDescription="@string/pp_terminal"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:visibility="gone"
            app:tint="@color/key_text" />

        <View
            android:id="@+id/ppTerminalSpacer"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnPpTranslate"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:minWidth="40dp"
            android:minHeight="0dp"
            android:background="@drawable/toggle_key_bg"
            android:text="en"
            android:textColor="@color/key_text"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:padding="0dp"
            android:contentDescription="@string/pp_translate" />
    </LinearLayout>

    <!-- Bottom row: paste, space, enter -->
    <LinearLayout
        android:id="@+id/bottomRow"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/ppToggleRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnSpace"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/key_bg"
            android:text=""
            android:textColor="@color/key_text"
            android:textSize="12sp" />

        <View
            android:layout_width="6dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnQuestion"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:background="@drawable/key_bg"
            android:text="?"
            android:textColor="@color/key_text"
            android:textSize="18sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp" />

        <View
            android:layout_width="6dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnExclamation"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:background="@drawable/key_bg"
            android:text="!"
            android:textColor="@color/key_text"
            android:textSize="18sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp" />

        <View
            android:layout_width="6dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnEnter"
            android:layout_width="52dp"
            android:layout_height="match_parent"
            android:background="@drawable/key_bg"
            android:src="@drawable/ic_enter"
            android:contentDescription="Enter"
            android:scaleType="centerInside"
            android:padding="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
